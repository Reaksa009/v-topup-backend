APP_NAME=V-TOPUP-STORE
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://vtopup-backend.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=info

# Database Connection (MongoDB Atlas)
DB_CONNECTION=mongodb
DB_URI=mongodb+srv://user:pass@cluster.mongodb.net/v-topup?retryWrites=true&w=majority
DB_DATABASE=v-topup
DB_MAX_POOL_SIZE=100
DB_MIN_POOL_SIZE=10

# Redis Cache, Session, and Queue configuration
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Redis Connection details
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# Production CORS Frontend URLs
FRONTEND_URL=https://v-topup-frontend.vercel.app
ADMIN_FRONTEND_URL=https://t-topup-admin.vercel.app
SANCTUM_STATEFUL_DOMAINS=v-topup-frontend.vercel.app,t-topup-admin.vercel.app

# Telegram Notifications Bot Info
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# KHQR Payment Gateway Config
